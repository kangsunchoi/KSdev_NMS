# ============================================================================
# NetVision OT — backend/.env  추가 설정 예시
# ----------------------------------------------------------------------------
# 이 파일(.env.example)은 안전한 플레이스홀더입니다. 실제 값은 VM의 backend/.env
# 에만 넣으세요 (backend/.env 는 .gitignore 로 커밋되지 않습니다).
#
# 아래 신규 항목은 전부 "기본 OFF" 입니다. 아무것도 추가하지 않고 배포하면
# 기존 동작과 100% 동일하게 돕니다. 필요할 때 하나씩 켜세요.
# ============================================================================

# --- 기존 항목 (참고) -------------------------------------------------------
# MONGO_URL="mongodb://localhost:27017"
# DB_NAME="netvision"
# CORS_ORIGINS="http://192.168.108.129:8080"
# SIMULATION_MODE=true

# --- 인증 / RBAC (기본 OFF) --------------------------------------------------
# true 로 바꾸면 로그인 + 권한제어가 켜집니다. (viewer < operator < admin)
AUTH_ENABLED=false
# 인증을 켤 때 반드시 설정 (없으면 재시작마다 로그인이 풀립니다).
# 생성 예: python3 -c "import secrets;print(secrets.token_hex(32))"
AUTH_SECRET=
# 첫 시작 시 만들어지는 관리자 계정 (AUTH_ENABLED=true 이고 사용자가 없을 때만)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-now
# 로그인 토큰 유효시간(시간)
AUTH_TOKEN_TTL_HOURS=12

# --- 수집 API 보호 (기본 OFF) -----------------------------------------------
# 값을 넣으면 /api/ingest, /api/metrics, /api/interfaces, /api/links,
# /api/discovery/register 가 X-Ingest-Token 헤더를 요구합니다.
# (켜면 Node-RED 플로우의 HTTP 노드에도 같은 헤더를 추가해야 합니다.)
INGEST_TOKEN=

# --- 감사 추적 (기본 ON, 비침습) --------------------------------------------
AUDIT_ENABLED=true
AUDIT_TTL_DAYS=30

# --- 알람 상관관계 RCA (기본 ON, 비침습 주석만) -----------------------------
RCA_ENABLED=true

# --- 알람 통지 (기본 OFF: 아래 값이 비어있으면 발송 안 함) -------------------
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 통지 최소 심각도: info | warning | critical
NOTIFY_MIN_SEVERITY=critical
